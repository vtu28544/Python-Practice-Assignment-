3. Factorial Using Iteration and Recursion
# Iterative
n = int(input("Enter a number: "))
fact = 1

for i in range(1, n + 1):
    fact *= i

print("Factorial (Iteration):", fact)

# Recursive
def factorial(n):
    if n == 0 or n == 1:
        return 1
    return n * factorial(n - 1)

print("Factorial (Recursion):", factorial(n))
